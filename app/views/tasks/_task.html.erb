<%= turbo_frame_tag dom_id(task) do %>
  <article class="group mx-4 my-3 flex gap-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm transition hover:border-slate-300 hover:shadow-md <%= "border-emerald-200 bg-emerald-50/40" if task.completed_at? %>" data-task-reorder-target="item" data-action="dragover->task-reorder#dragOver" data-id="<%= task.id %>">
    <button type="button" class="mt-1 inline-flex h-9 w-9 shrink-0 cursor-grab items-center justify-center rounded-md border border-slate-200 bg-slate-50 text-slate-400 transition hover:border-slate-300 hover:bg-white hover:text-slate-700 active:cursor-grabbing" data-task-reorder-target="handle" data-action="dragstart->task-reorder#dragStart dragend->task-reorder#dragEnd" aria-label="Reorder task" title="Reorder task">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16" />
        <path d="M4 12h16" />
        <path d="M4 17h16" />
      </svg>
    </button>

    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
        <span class="inline-flex h-6 items-center justify-center rounded-full px-2.5 <%= task.completed_at? ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700" %>"><%= task.completed_at? ? t(".status_done") : t(".status_open") %></span>
        <span class="inline-flex h-6 items-center justify-center rounded-full px-2.5 <%= { "whenever" => "bg-slate-100 text-slate-600", "low" => "bg-sky-100 text-sky-700", "medium" => "bg-emerald-100 text-emerald-700", "high" => "bg-amber-100 text-amber-700", "immediate" => "bg-rose-100 text-rose-700" }[task.priority] || "bg-slate-100 text-slate-700" %>"><%= task.priority.humanize %></span>
        <% if task.deadline.present? %>
          <span class="inline-flex h-6 items-center justify-center rounded-full bg-slate-100 px-2.5 text-slate-600"><%= task.deadline %></span>
        <% end %>
      </div>

      <p class="mt-3 text-sm leading-6 text-slate-800 <%= "line-through text-slate-400" if task.completed_at? %>"><%= task.task %></p>
    </div>

    <div class="flex shrink-0 flex-wrap items-start justify-end gap-2">
      <% if task.attachment_url %>
        <%= link_to task.attachment_url, download: "", target: "_blank", class: "inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-200 bg-white text-slate-500 transition hover:border-sky-200 hover:bg-sky-50 hover:text-sky-700", aria: { label: t(".download") }, title: t(".download") do %>
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v12" />
            <path d="m7 10 5 5 5-5" />
            <path d="M5 21h14" />
          </svg>
        <% end %>
      <% end %>
      <%= link_to edit_todo_task_path(@todo, task), data: { turbo_frame: dom_id(task) }, class: "inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-200 bg-white text-slate-500 transition hover:border-sky-200 hover:bg-sky-50 hover:text-sky-700", aria: { label: t(".edit") }, title: t(".edit") do %>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 20h9" />
          <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />
        </svg>
      <% end %>
      <%= button_to todo_task_path(@todo, task), method: :delete, form: { data: { turbo_confirm: t(".delete") }, class: "inline-flex" }, class: "inline-flex h-9 w-9 items-center justify-center rounded-md border border-rose-200 bg-white text-rose-500 transition hover:bg-rose-50 hover:text-rose-700", aria: { label: t(".delete") }, title: t(".delete") do %>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 6h18" />
          <path d="M8 6V4h8v2" />
          <path d="M19 6l-1 14H6L5 6" />
          <path d="M10 11v5" />
          <path d="M14 11v5" />
        </svg>
      <% end %>
      <%= button_to todo_task_path(@todo, task, task: { completed_at: !task.completed_at? }), method: :patch, form: { class: "inline-flex" }, class: "inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-200 bg-white text-slate-500 transition hover:border-emerald-200 hover:bg-emerald-50 hover:text-emerald-700", aria: { label: (task.completed_at? ? t(".reopen") : t(".confirm")) }, title: (task.completed_at? ? t(".reopen") : t(".confirm")) do %>
        <% if task.completed_at? %>
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 12a9 9 0 1 0 3-6.7" />
            <path d="M3 3v6h6" />
          </svg>
        <% else %>
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 6 9 17l-5-5" />
          </svg>
        <% end %>
      <% end %>
    </div>
  </article>
<% end %>
