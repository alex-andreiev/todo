<section class="mx-auto max-w-md">
  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <div class="mb-6">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Create account</p>
      <h1 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">Sign up</h1>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <%= f.error_notification %>
      <%= f.input :email, required: true, autofocus: true, input_html: { autocomplete: "email", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-950 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100" } %>
      <%= f.input :password, required: true, hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length), input_html: { autocomplete: "new-password", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-950 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100" } %>
      <%= f.input :password_confirmation, required: true, input_html: { autocomplete: "new-password", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-950 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100" } %>

      <%= f.button :submit, "Sign up", class: "inline-flex w-full items-center justify-center rounded-md bg-slate-950 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</section>
