<%= turbo_frame_tag dom_id(todo) do %>
  <article class="group mx-4 my-3 flex gap-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm transition hover:border-slate-300 hover:shadow-md" data-reorder-target="item" data-action="dragover->reorder#dragOver" data-id="<%= todo.id %>">
    <button type="button" class="mt-1 inline-flex h-9 w-9 shrink-0 cursor-grab items-center justify-center rounded-md border border-slate-200 bg-slate-50 text-slate-400 transition hover:border-slate-300 hover:bg-white hover:text-slate-700 active:cursor-grabbing" data-reorder-target="handle" data-action="dragstart->reorder#dragStart dragend->reorder#dragEnd" aria-label="Reorder list" title="Reorder list">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16" />
        <path d="M4 12h16" />
        <path d="M4 17h16" />
      </svg>
    </button>

    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-center gap-3">
        <%= link_to todo_path(todo), data: { turbo_frame: "_top" }, class: "min-w-0 truncate text-base font-semibold text-slate-950 transition hover:text-sky-700" do %>
          <%= todo.title %>
        <% end %>
        <span class="inline-flex h-6 items-center justify-center rounded-full bg-slate-100 px-2.5 text-xs font-semibold text-slate-600"><%= todo.tasks.size %> <%= t(".tasks") %></span>
      </div>

      <% if todo.description.present? %>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-500"><%= todo.description %></p>
      <% end %>
    </div>

    <div class="flex shrink-0 items-start gap-2">
      <%= link_to edit_todo_path(todo), data: { turbo_frame: dom_id(todo) }, class: "inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-200 bg-white text-slate-500 transition hover:border-sky-200 hover:bg-sky-50 hover:text-sky-700", aria: { label: t(".edit") }, title: t(".edit") do %>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 20h9" />
          <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />
        </svg>
      <% end %>
      <%= button_to todo_path(todo), method: :delete, form: { data: { turbo_confirm: t(".delete") }, class: "inline-flex" }, class: "inline-flex h-9 w-9 items-center justify-center rounded-md border border-rose-200 bg-white text-rose-500 transition hover:bg-rose-50 hover:text-rose-700", aria: { label: t(".delete") }, title: t(".delete") do %>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 6h18" />
          <path d="M8 6V4h8v2" />
          <path d="M19 6l-1 14H6L5 6" />
          <path d="M10 11v5" />
          <path d="M14 11v5" />
        </svg>
      <% end %>
    </div>
  </article>
<% end %>
