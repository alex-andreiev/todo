<section class="grid gap-6 lg:grid-cols-[minmax(0,1.7fr)_18rem]">
  <div class="space-y-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
        <div class="min-w-0 flex-1">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">List</p>
          <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950"><%= @todo.title %></h1>
          <% if @todo.description.present? %>
            <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-600"><%= @todo.description %></p>
          <% end %>
        </div>

        <div class="flex flex-wrap gap-2">
          <%= link_to t("todos.todo.edit"), edit_todo_path(@todo), data: { turbo_frame: dom_id(@todo) }, class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
          <%= button_to t("todos.todo.delete"), todo_path(@todo), method: :delete, form: { data: { turbo_confirm: t("todos.todo.delete") } }, class: "inline-flex items-center justify-center rounded-xl bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-rose-500" %>
        </div>
      </div>
    </div>

    <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
      <div class="flex items-center justify-between gap-4 border-b border-slate-200 px-6 py-4">
        <div>
          <h2 class="text-base font-semibold text-slate-950"><%= t(".tasks") %></h2>
          <p class="mt-1 text-sm text-slate-500"><%= @tasks_total_count.positive? ? "Manage each task inline." : t(".empty_tasks") %></p>
        </div>

        <%= turbo_frame_tag :new_task do %>
          <%= render "tasks/new_button" %>
        <% end %>
      </div>

      <div id="tasks" class="divide-y divide-slate-200" data-controller="task-reorder" data-todo-id="<%= @todo.id %>" data-position-offset="<%= @pagy.offset %>">
        <% if @tasks.any? %>
          <%= render partial: "tasks/task", collection: @tasks, as: :task %>
        <% else %>
          <div id="tasks_empty" class="px-6 py-12 text-center text-sm text-slate-500"><%= t(".empty_tasks") %></div>
        <% end %>
      </div>

      <%= render "shared/pagination", pagy: @pagy %>
    </div>
  </div>

  <aside class="space-y-4">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Overview</p>
      <dl class="mt-4 space-y-4">
        <div class="flex items-center justify-between">
          <dt class="text-sm text-slate-500">Tasks</dt>
          <dd class="text-lg font-semibold text-slate-950"><%= @tasks_total_count %></dd>
        </div>
        <div class="flex items-center justify-between">
          <dt class="text-sm text-slate-500">Open</dt>
          <dd class="text-lg font-semibold text-slate-950"><%= @open_tasks_count %></dd>
        </div>
        <div class="flex items-center justify-between">
          <dt class="text-sm text-slate-500">Completed</dt>
          <dd class="text-lg font-semibold text-slate-950"><%= @completed_tasks_count %></dd>
        </div>
      </dl>
    </div>
  </aside>
</section>
