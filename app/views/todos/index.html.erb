<section class="space-y-6">
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0 flex-1">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400"><%= t(".lists") %></p>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950"><%= t(".lists") %></h1>
        <p class="mt-1 text-sm text-slate-500"><%= t(".subtitle") %></p>
      </div>

      <%= render "new_button" %>
    </div>
  </div>

  <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
    <div class="flex items-center justify-between gap-4 border-b border-slate-200 px-6 py-4">
      <div>
        <h2 class="text-base font-semibold text-slate-950"><%= t(".lists") %></h2>
        <p class="mt-1 text-sm text-slate-500"><%= @pagy.count.positive? ? pluralize(@pagy.count, "list") : t(".empty") %></p>
      </div>
    </div>

    <div id="todos" class="divide-y divide-slate-200" data-controller="reorder" data-position-offset="<%= @pagy.offset %>">
      <% if @todos.any? %>
        <%= render partial: "todo", collection: @todos, as: :todo %>
      <% else %>
        <div class="px-6 py-12 text-center text-sm text-slate-500"><%= t(".empty") %></div>
      <% end %>
    </div>

    <%= render "shared/pagination", pagy: @pagy %>
  </div>
</section>
