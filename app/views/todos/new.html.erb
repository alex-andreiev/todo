<turbo-frame id="todo_form">
  <section class="mx-auto max-w-2xl rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400"><%= t("todos.index.new") %></p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950"><%= t("todos.index.new") %></h1>
    </div>
    <div class="mt-6">
      <%= render "form", todo: @todo, cancel_path: todos_path %>
    </div>
  </section>
</turbo-frame>
