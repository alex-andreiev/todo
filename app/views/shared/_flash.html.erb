<% flash.each do |type, message| %>
  <% next if message.blank? %>
  <% style = type.to_s == "notice" ? "border-emerald-200 bg-emerald-50 text-emerald-800" : "border-rose-200 bg-rose-50 text-rose-800" %>
  <div data-controller="flash" role="status" class="mb-3 flex items-start justify-between gap-4 rounded-2xl border px-4 py-3 text-sm <%= style %>">
    <p class="pt-0.5"><%= message %></p>
    <button type="button" data-action="flash#dismiss" class="rounded-full p-1 text-current/70 transition hover:bg-black/5 hover:text-current" aria-label="Dismiss">
      &times;
    </button>
  </div>
<% end %>
